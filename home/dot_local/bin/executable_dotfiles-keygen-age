#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────
# WHAT  : generate the user's age keypair for SOPS-encrypted secrets.
#         Idempotent: refuses to overwrite an existing keyfile.
# WHERE : home/dot_local/bin/executable_dotfiles-keygen-age
#         → ~/.local/bin/dotfiles-keygen-age
# WHY   : age key generation is one command but easy to fumble (wrong
#         path, no chmod 600, key printed to a logged terminal). This
#         helper enforces the right defaults so secrets can be encrypted
#         immediately after install.
#
# Usage:
#   dotfiles-keygen-age           # creates the key, prints public part
#   dotfiles-keygen-age --pub     # only re-print the public part
#   dotfiles-keygen-age --force   # regenerate (DANGER — old secrets become
#                                   undecryptable unless re-keyed)
# ─────────────────────────────────────────────────────────────────────────

set -euo pipefail

KEYFILE="${SOPS_AGE_KEY_FILE:-${XDG_CONFIG_HOME:-$HOME/.config}/sops/age/keys.txt}"

red() { printf '\033[1;31m%s\033[0m\n' "$*" >&2; }
yellow() { printf '\033[1;33m%s\033[0m\n' "$*" >&2; }
green() { printf '\033[1;32m%s\033[0m\n' "$*"; }
blue() { printf '\033[1;34m%s\033[0m\n' "$*"; }

action="generate"
case "${1:-}" in
--pub) action="print_pub" ;;
--force) action="force" ;;
-h | --help)
    sed -n '/^# Usage:/,/^# ──/p' "$0" | sed 's/^# \{0,1\}//'
    exit 0
    ;;
"") ;;
*)
    red "unknown flag: $1"
    exit 1
    ;;
esac

if [ "$action" = "print_pub" ]; then
    if [ ! -f "$KEYFILE" ]; then
        red "no keyfile at $KEYFILE — run dotfiles-keygen-age first"
        exit 1
    fi
    age-keygen -y "$KEYFILE"
    exit 0
fi

if [ -f "$KEYFILE" ] && [ "$action" != "force" ]; then
    yellow "keyfile already exists at $KEYFILE — refusing to overwrite"
    yellow "use --force to regenerate (old SOPS-encrypted secrets become unreadable!)"
    blue "current public key:"
    age-keygen -y "$KEYFILE"
    exit 0
fi

if ! command -v age-keygen >/dev/null 2>&1; then
    red "age-keygen not found — add 'age' to your TUI tool selection and re-apply"
    exit 1
fi

mkdir -p "$(dirname "$KEYFILE")"
chmod 700 "$(dirname "$KEYFILE")"

# Atomic write: keygen to tempfile, chmod 600, then mv into place.
tmp="$(mktemp "${KEYFILE}.XXXXXX")"
trap 'rm -f "$tmp"' EXIT
age-keygen -o "$tmp" 2>/dev/null
chmod 600 "$tmp"
mv "$tmp" "$KEYFILE"
trap - EXIT

green "✓ age key created at $KEYFILE (chmod 600)"
echo
blue "your public recipient — paste into .sops.yaml:"
age-keygen -y "$KEYFILE"
echo
yellow "BACK UP $KEYFILE NOW. Lose it = lose every SOPS-encrypted secret."
yellow "Recommended targets: a password manager (1Password / Bitwarden) or"
yellow "an encrypted USB stick stored offline. Never commit it."
