#!/usr/bin/env bash
# dotfiles-update — refresh system pkgs + chezmoi + LazyVim plugins.
#
#   dotfiles-update              # full pass
#   dotfiles-update --no-pkg     # skip system package upgrade

set -euo pipefail

step() { printf '\033[1;34m==> %s\033[0m\n' "$*"; }
ok()   { printf '\033[32m  ✓ %s\033[0m\n' "$*"; }
warn() { printf '\033[33m  ! %s\033[0m\n' "$*" >&2; }
have() { command -v "$1" >/dev/null 2>&1; }

NO_PKG=0
for arg in "$@"; do
    case "$arg" in
        --no-pkg) NO_PKG=1 ;;
        -h|--help)
            echo "usage: dotfiles-update [--no-pkg]"
            exit 0
            ;;
        *) echo "unknown flag: $arg" >&2; exit 2 ;;
    esac
done

SUDO=""
[ "$(id -u 2>/dev/null || echo 0)" -ne 0 ] && have sudo && SUDO="sudo"

if [ "$NO_PKG" -eq 0 ]; then
    case "$(uname -s)" in
    Linux)
        if have pacman; then
            step "pacman -Syu"; ${SUDO} pacman -Syu --noconfirm
        elif have apt-get; then
            step "apt update && upgrade"
            ${SUDO} apt-get update && ${SUDO} apt-get upgrade -y
        fi
        ;;
    MINGW*|MSYS*|CYGWIN*)
        have scoop && { step "scoop update *"; scoop update; scoop update '*' || warn "some scoop apps failed"; }
        ;;
    esac
fi

if have chezmoi; then
    step "chezmoi update"
    chezmoi update --apply
fi

if have nvim; then
    step "nvim — Lazy! sync"
    nvim --headless "+Lazy! sync" +qa 2>/dev/null || warn "Lazy sync returned non-zero"
fi

if have claude; then
    step "claude — self-update"
    claude update 2>/dev/null || warn "claude update unsupported"
fi
if have bun && have omp; then
    step "omp — bun update"
    bun update -g @oh-my-pi/pi-coding-agent || warn "omp update returned non-zero"
fi

step "done"
ok "open a new shell to pick up any changes"
