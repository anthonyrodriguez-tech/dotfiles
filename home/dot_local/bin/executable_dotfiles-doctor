#!/usr/bin/env bash
# dotfiles-doctor — quick health check.

set -u

step() { printf '\033[1;34m==> %s\033[0m\n' "$*"; }
ok()   { printf '\033[32m  OK   %s\033[0m\n' "$*"; }
miss() { printf '\033[31m  MISS %s\033[0m\n' "$*"; }
warn() { printf '\033[33m  WARN %s\033[0m\n' "$*"; }
have() { command -v "$1" >/dev/null 2>&1; }

REQUIRED=(zsh git nvim chezmoi fzf zoxide rg fd bat eza starship lazygit delta jq)
OPTIONAL=(gh tmux yq claude omp wezterm)

MISS=0
WARNS=0

step "binaries on PATH"
for b in "${REQUIRED[@]}"; do
    if have "$b"; then ok "$b ($(command -v "$b"))"; else miss "$b — required"; MISS=$((MISS+1)); fi
done
for b in "${OPTIONAL[@]}"; do
    if have "$b"; then ok "$b ($(command -v "$b"))"; else warn "$b — optional"; WARNS=$((WARNS+1)); fi
done

step "local overrides"
for f in "${HOME}/.gitconfig.local" "${HOME}/.gitconfig.work" \
    "${XDG_CONFIG_HOME:-${HOME}/.config}/zsh/local.zsh"; do
    [ -f "$f" ] && ok "$f present"
done

if have chezmoi; then
    step "chezmoi doctor"
    chezmoi doctor || WARNS=$((WARNS+1))
fi

if have nvim; then
    step "nvim startup smoke"
    if nvim --headless +qa 2>/tmp/dotfiles-doctor-nvim.err; then
        if [ -s /tmp/dotfiles-doctor-nvim.err ]; then
            warn "nvim wrote to stderr on startup:"
            sed 's/^/         /' /tmp/dotfiles-doctor-nvim.err
            WARNS=$((WARNS+1))
        else
            ok "nvim starts cleanly"
        fi
    else
        miss "nvim failed to start"; MISS=$((MISS+1))
    fi
    rm -f /tmp/dotfiles-doctor-nvim.err
fi

step "summary"
if [ "$MISS" -eq 0 ] && [ "$WARNS" -eq 0 ]; then
    printf '\033[1;32m  ✓ all clear\033[0m\n'
    exit 0
fi
printf '  %d missing, %d warnings\n' "$MISS" "$WARNS"
[ "$MISS" -gt 0 ] && exit 1
exit 0
