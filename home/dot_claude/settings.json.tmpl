{
  "_comment": "Claude Code user settings — see https://docs.claude.com/en/docs/claude-code/settings",

  "includeCoAuthoredBy": true,
  "cleanupPeriodDays": 30,
  "model": "claude-sonnet-4-6",

  "env": {
    "EDITOR": "nvim",
    "BAT_THEME": "Catppuccin Mocha"
{{- if .proxy_http }},
    "HTTP_PROXY":  {{ .proxy_http  | quote }},
    "HTTPS_PROXY": {{ .proxy_https | quote }},
    "NO_PROXY":    "localhost,127.0.0.1"
{{- end }}
  },

  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(rg:*)",
      "Bash(fd:*)",
      "Bash(eza:*)",
      "Bash(chezmoi:*)",
      "Bash(gh:*)",
      "Bash(jq:*)",
      "Bash(yq:*)"
    ],
    "deny": [
      "Bash(rm -rf /:*)",
      "Bash(sudo rm:*)"
    ]
  }
}
