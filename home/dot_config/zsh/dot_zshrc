# ~/.config/zsh/.zshrc — interactive zsh entry point. KISS, no framework.
# ZDOTDIR is set in ~/.zshenv so zsh finds this file under $XDG_CONFIG_HOME.

case "$(uname -s)" in
    Linux)                export DOTFILES_OS=linux ;;
    MINGW*|MSYS*|CYGWIN*) export DOTFILES_OS=windows ;;
    *)                    export DOTFILES_OS=unknown ;;
esac

local _zsh_modules=(
    options
    env
    history
    path
    completion
    aliases
    functions
    keybinds
    integrations
)

for _mod in "${_zsh_modules[@]}"; do
    local _f="$ZDOTDIR/$_mod.zsh"
    [[ -r "$_f" ]] && source "$_f"
done
unset _mod _f _zsh_modules

# Per-machine overrides — never tracked.
[[ -r "$ZDOTDIR/local.zsh" ]] && source "$ZDOTDIR/local.zsh"
