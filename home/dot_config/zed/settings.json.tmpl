{{- /*
  Zed editor settings — minimalist defaults.
  Ignored when "zed" is not in .editors (.chezmoiignore handles that).
  Zed has no stable Windows build yet, so this template is also ignored
  on Windows.
*/ -}}
{
    "theme": "One Dark",
    "buffer_font_family": "JetBrainsMono Nerd Font",
    "buffer_font_size": 14,
    "ui_font_size": 16,

    "vim_mode": true,
    "relative_line_numbers": true,
    "format_on_save": "on",
    "ensure_final_newline_on_save": true,
    "remove_trailing_whitespace_on_save": true,
    "tab_size": 4,

    "telemetry": {
        "diagnostics": false,
        "metrics": false
    },

    "terminal": {
        "shell": {
            "program": "zsh"
        },
        "font_family": "JetBrainsMono Nerd Font",
        "font_size": 13
    },

    "git": {
        "git_gutter": "tracked_files",
        "inline_blame": {
            "enabled": false
        }
    }
}
