# ─── OS cruft ─────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─── Editor / IDE swap files ──────────────────────────────────────────────
*.swp
*.swo
*.swn
*~
.*.sw?
*.bak
*.tmp
.vscode/
.idea/

# ─── chezmoi local state (never commit applied state) ─────────────────────
# chezmoi's state/cache lives in the target machine's $XDG_DATA_HOME.
# We only guard against accidental drops of `chezmoi dump` outputs here.
chezmoi-dump.*
chezmoi-state.*

# ─── Secrets / local overrides (should never reach this repo) ─────────────
*.local
*.local.zsh
.env
.env.*
!.env.example
secrets.yaml
age.key
*.pem
*.key

# ─── Build artefacts from tooling we might run from the repo root ─────────
node_modules/
.direnv/
.cache/

# ─── chezmoi source state — un-ignore against the user's global ignores ──
# Some users have a global `~/.gitignore` rule like `bin/` to keep their
# build outputs out of every repo. That accidentally hides our chezmoi
# source state under `home/dot_local/bin/`, which is intentionally tracked
# (it ships dotfiles-update / dotfiles-doctor). Force-include it.
!home/dot_local/bin/
!home/dot_local/bin/**
