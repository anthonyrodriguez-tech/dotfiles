# WHAT  : editorconfig — per-filetype indentation.
# WHERE : .editorconfig (repo root)
# WHY   : keeps shfmt / stylua / prettier / treesitter from fighting over
#         tabs vs spaces. 4 spaces is the project-wide default; YAML and
#         JSON drop to 2 because that's what the ecosystems expect.

root = true

[*]
charset           = utf-8
end_of_line       = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style      = space
indent_size       = 4

[*.{yml,yaml,json,tmpl}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false   # preserve two-space line breaks

[{Makefile,*.mk}]
indent_style = tab
